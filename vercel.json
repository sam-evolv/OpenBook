{
  "framework": "nextjs",
  "regions": ["dub1"],
  "crons": [
    {
      "path": "/api/cron/notify-waitlist",
      "schedule": "* * * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/signup",
      "destination": "/onboard",
      "permanent": false
    }
  ]
}
