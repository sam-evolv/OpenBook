{
  "framework": "nextjs",
  "regions": ["dub1"],
  "crons": [
    { "path": "/api/cron/post-visit-recap", "schedule": "*/15 * * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://*.openbook.ie https://*.vercel.app http://localhost:3000 http://127.0.0.1:3000"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/signup",
      "destination": "/onboard",
      "permanent": false
    }
  ]
}
