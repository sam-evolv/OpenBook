# ============================================================================
# REQUIRED — the core app needs these to run.
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# OPTIONAL — every block below can be left blank in production. The app
# detects each one via lib/integrations.ts and falls back gracefully:
#   - Missing Stripe   → onboarding "Payments coming soon", finance shows
#                        the connect card, bookings still work (manual pay).
#   - Missing Resend   → bookings still succeed, email confirmation skipped.
#   - Missing OpenAI   → /assistant returns a friendly placeholder, AI
#                        reply chips silently hide, WhatsApp auto-reply is
#                        skipped (inbound still logs to the inbox).
#   - Missing WhatsApp → webhook returns 404, dashboard send action shows
#                        "WhatsApp messaging not enabled" message.
# ============================================================================
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

RESEND_API_KEY=

OPENAI_API_KEY=

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Used by the marketing site to link CTAs ("Get started", "Sign in", "Demo")
# to the main OpenBook app. Marketing lives at www.openbook.ie; the app lives
# at app.openbook.ie — override this in Vercel once that's wired up.
NEXT_PUBLIC_APP_URL=https://app.openbook.ie
