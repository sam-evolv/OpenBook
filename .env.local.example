NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# MCP server (and existing service-role workflows) — required for rate limiting
# and tool-call logging at /api/mcp.
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

RESEND_API_KEY=

OPENAI_API_KEY=

# MCP — token signing keys (32+ bytes each; generate with `openssl rand -hex 32`).
# Two distinct secrets so a key compromise on one token type doesn't grant the other.
MCP_HOLD_SIGNING_KEY=
MCP_POLLING_TOKEN_KEY=

# MCP — host the signed checkout URL points at. Default is app.openbook.ie;
# the next PR (checkout page) will own this route. Required in production.
APP_DOMAIN=app.openbook.ie

# MCP — secret used to authorise the /api/cron/notify-waitlist endpoint.
# Vercel sets `Authorization: Bearer <this>` automatically when invoking
# crons declared in vercel.json. Generate with `openssl rand -hex 32`.
VERCEL_CRON_SECRET=

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Used by the marketing site to link CTAs ("Get started", "Sign in", "Demo")
# to the main OpenBook app. Marketing lives at www.openbook.ie; the app lives
# at app.openbook.ie — override this in Vercel once that's wired up.
NEXT_PUBLIC_APP_URL=https://app.openbook.ie
